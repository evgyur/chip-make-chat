MAKE_CHAT_OWNER_USER_ID=123456789
MAKE_CHAT_BOT_USERNAME=my_super_bot
MAKE_CHAT_API_BASE=http://127.0.0.1:18080
MAKE_CHAT_CONFIG_PATH=$HOME/.openclaw/openclaw.json
MAKE_CHAT_BACKUP_DIR=$HOME/.cache/chip-make-chat/backups
MAKE_CHAT_CONFIG_LOCK_PATH=$HOME/.openclaw/locks/chip-make-chat.lock
MAKE_CHAT_LEDGER_PATH=$HOME/.openclaw/state/chip-make-chat-ledger.json
MAKE_CHAT_BOT_TOKEN_FILE=$HOME/.openclaw/secrets/telegram-bot-token
MAKE_CHAT_GATEWAY_STATUS_CMD=openclaw gateway status
MAKE_CHAT_LEDGER_STALE_SECONDS=300
